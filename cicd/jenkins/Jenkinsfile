pipeline {
    agent any
    environment {
        AWS_REGION = 'us-east-1'
        TERRAFORM_DIR = 'terraform/environments/prod'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Terraform Plan') {
            steps {
                dir("${TERRAFORM_DIR}") {
                    sh 'terraform init'
                    sh 'terraform plan'
                }
            }
        }
        stage('Approval') {
            steps {
                input message: 'Deploy to Production?'
            }
        }
        stage('Terraform Apply') {
            steps {
                dir("${TERRAFORM_DIR}") {
                    sh 'terraform apply -auto-approve'
                }
            }
        }
    }
}