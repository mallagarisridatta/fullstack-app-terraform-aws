{
  "pipeline": {
    "name": "EnterpriseAppPipeline",
    "roleArn": "arn:aws:iam::ACCOUNT_ID:role/CodePipelineRole",
    "artifactStore": {
      "type": "S3",
      "location": "codepipeline-artifacts-bucket"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "Source",
            "actionTypeId": {
              "category": "Source",
              "owner": "ThirdParty",
              "provider": "GitHub",
              "version": "1"
            },
            "outputArtifacts": [ { "name": "SourceArtifact" } ],
            "configuration": {
              "Owner": "mallagarisridatta",
              "Repo": "fullstack-app-terraform-aws",
              "Branch": "main",
              "OAuthToken": "{{resolve:secretsmanager:github-token:secret-string:token}}"
            }
          }
        ]
      },
      {
        "name": "Build",
        "actions": [
          {
            "name": "BuildApp",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "inputArtifacts": [ { "name": "SourceArtifact" } ],
            "outputArtifacts": [ { "name": "BuildArtifact" } ],
            "configuration": {
              "ProjectName": "EnterpriseAppBuild"
            }
          }
        ]
      }
    ]
  }
}