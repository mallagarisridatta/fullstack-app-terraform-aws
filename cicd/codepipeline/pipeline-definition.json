{
  "pipeline": {
    "name": "EnterpriseAppPipeline",
    "roleArn": "arn:aws:iam::123456789012:role/CodePipelineServiceRole",
    "artifactStore": {
      "type": "S3",
      "location": "codepipeline-artifacts-bucket"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [{
          "name": "Source",
          "actionTypeId": {
            "category": "Source",
            "owner": "ThirdParty",
            "provider": "GitHub",
            "version": "1"
          },
          "outputArtifacts": [{"name": "SourceArtifact"}],
          "configuration": {
            "Owner": "mallagarisridatta",
            "Repo": "fullstack-app-terraform-aws",
            "Branch": "main"
          }
        }]
      },
      {
        "name": "Build",
        "actions": [{
          "name": "BuildBackend",
          "actionTypeId": {
            "category": "Build",
            "owner": "AWS",
            "provider": "CodeBuild",
            "version": "1"
          },
          "inputArtifacts": [{"name": "SourceArtifact"}],
          "outputArtifacts": [{"name": "BuildArtifact"}],
          "configuration": {
            "ProjectName": "BackendBuildProject"
          }
        }]
      }
    ]
  }
}