{
  "pipeline": {
    "name": "FullstackAppPipeline",
    "roleArn": "arn:aws:iam::123456789012:role/CodePipelineServiceRole",
    "artifactStore": {
      "type": "S3",
      "location": "codepipeline-us-east-1-123456789012"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "SourceAction",
            "actionTypeId": {
              "category": "Source",
              "owner": "ThirdParty",
              "provider": "GitHub",
              "version": "1"
            },
            "outputArtifacts": [ { "name": "SourceArtifact" } ],
            "configuration": {
              "Owner": "mallagarisridatta",
              "Repo": "fullstack-app-terraform-aws",
              "Branch": "main",
              "OAuthToken": "{{resolve:secretsmanager:github-token:secret-string:token}}"
            }
          }
        ]
      },
      {
        "name": "Build",
        "actions": [
          {
            "name": "BuildAndTerraform",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "inputArtifacts": [ { "name": "SourceArtifact" } ],
            "configuration": {
              "ProjectName": "FullstackAppBuild"
            }
          }
        ]
      }
    ]
  }
}